{#
  Mini-panier à inclure dans la navbar :
  {{ include('cart/_mini_cart.html.twig') }}
#}
<a href="{{ path('cart_index') }}" style="position:relative; display:inline-flex; align-items:center; text-decoration:none; color:inherit;">
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75">
        <circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/>
        <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/>
    </svg>
    {% set count = app.session.get('_cart_count', 0) %}
    {# Idéalement, injecter le compte via CartService dans un Twig Extension #}
    {% if count > 0 %}
        <span style="
            position:absolute; top:-8px; right:-8px;
            background:#e63946; color:#fff; border-radius:99px;
            font-size:.65rem; font-family:sans-serif; font-weight:700;
            padding:.1rem .4rem; line-height:1.4;
        ">{{ count }}</span>
    {% endif %}
</a>
