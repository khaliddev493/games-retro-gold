{% extends 'base.html.twig' %}

{% block title %}{{ category.name }} — RetroGames{% endblock %}

{% block body %}
<div class="container py-5">

    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="{{ path('home') }}" style="color:var(--retro-cyan)">Accueil</a></li>
            <li class="breadcrumb-item"><a href="{{ path('category_index') }}" style="color:var(--retro-cyan)">Catégories</a></li>
            <li class="breadcrumb-item active text-light">{{ category.name }}</li>
        </ol>
    </nav>

    <h1 class="section-title"><i class="bi bi-tv"></i> {{ category.name }}</h1>
    <p class="text-muted mb-5">{{ category.description }}</p>

    <div class="row g-4">
        {% for product in category.products %}
            <div class="col-sm-6 col-lg-4">
                <div class="card">
                    <img src="{{ product.imageUrl }}"
                         class="card-img-top"
                         alt="{{ product.name }}"
                         onerror="this.src='https://placehold.co/300x200/2a1040/e0e0e0?text=No+Image'">
                    <div class="card-body d-flex flex-column">
                        <div class="d-flex justify-content-between mb-2">
                            <span class="badge-platform">{{ product.platform }}</span>
                            <small class="text-muted">{{ product.releaseYear }}</small>
                        </div>
                        <h5 class="card-title">{{ product.name }}</h5>
                        <p class="card-text flex-grow-1">{{ product.description|u.truncate(90, '…', false) }}</p>
                        <div class="d-flex justify-content-between align-items-center mt-3">
                            <span class="price">{{ product.price|number_format(2, ',', '\u00a0') }} €</span>
                            <a href="{{ path('product_show', {id: product.id}) }}" class="btn btn-retro">Détails</a>
                        </div>
                    </div>
                </div>
            </div>
        {% else %}
            <p class="text-muted">Aucun jeu dans cette catégorie.</p>
        {% endfor %}
    </div>

    <div class="mt-5">
        <a href="{{ path('category_index') }}" class="btn btn-retro">
            <i class="bi bi-arrow-left"></i> Retour aux catégories
        </a>
    </div>

</div>
{% endblock %}
