 {% extends 'base.html.twig' %}

{% block title %}Dashboard — RetroGames{% endblock %}

{% block body %}
<div class="container" style="padding: 3rem 1rem;">

    <!-- HEADER -->
    <div style="margin-bottom: 2.5rem;">
        <p style="font-family:'Cinzel',serif; color:var(--text-muted);
                  font-size:.75rem; letter-spacing:2px; text-transform:uppercase; margin-bottom:.4rem;">
            🎮 Espace client
        </p>

        <h1 style="font-family:'Cinzel',serif; font-size:1.6rem; font-weight:700;
                   color:var(--text-primary); letter-spacing:2px;">
            Bonjour, <span style="color:var(--gold);">{{ user.firstName }}</span> 👾
        </h1>

        <p style="color:var(--text-muted); font-size:.85rem; margin-top:.4rem;">
            Bienvenue sur votre espace personnel RetroGames
        </p>
    </div>

    <!-- INFOS UTILISATEUR -->
    <div style="display:grid; grid-template-columns: repeat(auto-fit, minmax(220px,1fr)); gap:1.25rem; margin-bottom:2.5rem;">

        <div class="card-retro">
            <strong>Nom complet :</strong><br>
            {{ user.firstName }} {{ user.lastName }}
        </div>

        <div class="card-retro">
            <strong>Email :</strong><br>
            {{ user.email }}
        </div>

        <div class="card-retro">
            <strong>Membre depuis :</strong><br>
            {{ user.createdAt|date('d/m/Y') }}
        </div>

        <div class="card-retro">
            <strong>Statut :</strong><br>
            {% if 'ROLE_ADMIN' in user.roles %}
                ⭐ Administrateur
            {% else %}
                ✔ Client vérifié
            {% endif %}
        </div>

    </div>

    <!-- ACTIONS -->
    <div style="margin-bottom:2rem;">
        <h3 style="margin-bottom:1rem;">Actions rapides</h3>

        <div style="display:flex; flex-wrap:wrap; gap:1rem;">
            <a href="{{ path('app_dashboard') }}" class="btn-retro">
                Parcourir les jeux
            </a>

            <a href="#" class="btn-retro">
                Mes commandes
            </a>

            <a href="{{ path('app_profile') }}" class="btn-retro">
                Mon profil
            </a>

            <a href="{{ path('app_logout') }}" class="btn-retro" style="background:#b33939;">
                Déconnexion
            </a>
        </div>
    </div>

    <!-- COMMANDES -->
    <div>
        <h3 style="margin-bottom:1rem;">Dernières commandes</h3>

        <p style="color:var(--text-muted);">
            Vous n'avez pas encore passé de commande.
        </p>

        <a href="{{ path('app_dashboard') }}" class="btn-retro">
            Découvrir nos jeux
        </a>
    </div>

</div>
{% endblock %}