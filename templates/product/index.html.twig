{% extends 'base.html.twig' %}

{% block title %}Tous les jeux — RetroGames{% endblock %}

{% block body %}
<div class="container py-4">

    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="{{ path('home') }}">Accueil</a></li>
            <li class="breadcrumb-item active">Tous les jeux</li>
        </ol>
    </nav>

    <h1 class="section-title"><i class="bi bi-grid-fill"></i> Tous les jeux rétro</h1>

    {# ── Formulaire de recherche ── #}
    <form method="get" action="{{ path('product_index') }}" class="mb-4">
        <div class="input-group">
            <input type="text"
                   name="q"
                   class="form-control"
                   placeholder="Rechercher un jeu…"
                   value="{{ query }}">
            <button type="submit" class="btn-retro">
                <i class="bi bi-search"></i> Rechercher
            </button>
        </div>
        {% if query %}
            <small class="text-muted mt-2 d-block">
                {{ products|length }} résultat(s) pour "<strong>{{ query }}</strong>"
                — <a href="{{ path('product_index') }}" style="color: var(--gold);">Effacer</a>
            </small>
        {% endif %}
    </form>

    {# ── Grille produits ── #}
    <div class="row g-4">
        {% for product in products %}
            <div class="col-6 col-md-3">

<div class="card h-100">
        <img src="{{ product.imageUrl }}"
             style="height:290px; object-fit:contain; padding:10px;


                          alt="{{ product.name }}"
                         onerror="this.src='https://placehold.co/400x280/141414/c9a84c?text=No+Image'">
                    <div class="card-body d-flex flex-column">
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <span class="badge-platform">{{ product.platform }}</span>
                            <small style="color:var(--text-muted);">{{ product.releaseYear }}</small>
                        </div>
                        <h5 class="card-title">{{ product.name }}</h5>
                        <p class="card-text flex-grow-1">{{ product.description|u.truncate(80, '…', false) }}</p>
                        <small class="mb-2">
                            <i class="bi bi-tag-fill" style="color:var(--gold-dark);"></i>
                            <a href="{{ path('category_show', {id: product.category.id}) }}"
                               style="color:var(--gold); font-size:.8rem;">
                                {{ product.category.name }}
                            </a>
                        </small>
                        <div class="d-flex justify-content-between align-items-center mt-auto pt-2">
                            <span class="price">{{ product.price|number_format(2, ',', '\u00a0') }} €</span>
                            <a href="{{ path('product_show', {id: product.id}) }}" class="btn-retro">
                                Détails
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        {% else %}
            <div class="col-12" style="text-align:center; padding:3rem 0;">
                <i class="bi bi-joystick" style="font-size:3rem; color:var(--gold-dark); display:block; margin-bottom:1rem;"></i>
                <p style="color:var(--text-muted); font-family:'Cinzel',serif; font-size:.85rem; letter-spacing:1px;">
                    {% if query %}
                        Aucun jeu trouvé pour "<strong style="color:var(--gold);">{{ query }}</strong>".
                        <br><br>
                        <a href="{{ path('product_index') }}" class="btn-retro" style="display:inline-flex;">
                            <i class="bi bi-arrow-left"></i> Voir tous les jeux
                        </a>
                    {% else %}
                        Aucun jeu disponible pour le moment.
                    {% endif %}
                </p>
            </div>
        {% endfor %}
    </div>

</div>
{% endblock %}