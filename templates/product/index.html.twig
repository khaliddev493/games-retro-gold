{% extends 'base.html.twig' %}

{% block title %}Tous les jeux — RetroGames{% endblock %}

{% block body %}
<div class="container py-5">

    <h1 class="section-title"><i class="bi bi-grid-fill"></i> Tous les jeux rétro</h1>

    <div class="row g-4">
        {% for product in products %}
            <div class="col-sm-6 col-lg-4">
                <div class="card">
                    <img src="{{ product.imageUrl }}"
                         class="card-img-top"
                         alt="{{ product.name }}"
                         onerror="this.src='https://placehold.co/300x200/2a1040/e0e0e0?text=No+Image'">
                    <div class="card-body d-flex flex-column">
                        <div class="d-flex justify-content-between mb-2">
                            <span class="badge-platform">{{ product.platform }}</span>
                            <small class="text-muted">{{ product.releaseYear }}</small>
                        </div>
                        <h5 class="card-title">{{ product.name }}</h5>
                        <p class="card-text flex-grow-1">{{ product.description|u.truncate(90, '…', false) }}</p>
                        <small class="text-muted mb-2">
                            <i class="bi bi-tag-fill"></i>
                            <a href="{{ path('category_show', {id: product.category.id}) }}"
                               style="color:var(--retro-cyan); text-decoration:none">
                                {{ product.category.name }}
                            </a>
                        </small>
                        <div class="d-flex justify-content-between align-items-center mt-2">
                            <span class="price">{{ product.price|number_format(2, ',', '\u00a0') }} €</span>
                            <a href="{{ path('product_show', {id: product.id}) }}" class="btn btn-retro">Détails</a>
                        </div>
                    </div>
                </div>
            </div>
        {% else %}
            <p class="text-muted">Aucun jeu disponible pour le moment.</p>
        {% endfor %}
    </div>

</div>
{% endblock %}
